{
  "name": "floatnote",
  "productName": "FloatNote",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && electron-builder",
    "build:ci": "tsc -b && vite build && electron-builder --publish never",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "preview": "vite preview"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.14"
  },
  "build": {
    "appId": "com.floatnote.app",
    "productName": "FloatNote",
    "icon": "public/icon.png",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "public/icon.png"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ]
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.7",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^5.4.21"
  }
}
